# Development Dockerfile - for local dev with hot reload
FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
# postinstall runs prisma generate; Prisma config + schema must exist before npm ci
COPY prisma ./prisma
COPY prisma.config.ts ./prisma.config.ts
RUN npm ci
COPY . .
EXPOSE 1100
CMD ["npm", "run", "dev"]
