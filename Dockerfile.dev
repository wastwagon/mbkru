# Development image: deps installed here; bind-mount the repo at runtime for hot reload.
FROM node:20-alpine
RUN apk add --no-cache libc6-compat openssl
WORKDIR /app
COPY package.json package-lock.json* ./
# postinstall runs prisma generate; Prisma config + schema must exist before npm ci
COPY prisma ./prisma
COPY prisma.config.ts ./prisma.config.ts
RUN npm ci
COPY . .
RUN chmod +x /app/docker-dev-entrypoint.sh
EXPOSE 1100
ENTRYPOINT ["/app/docker-dev-entrypoint.sh"]
