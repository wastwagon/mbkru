# MBKRU website — copy to .env and fill in (never commit .env)

# Public site URL (used for metadata, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:1100

# Platform phase at build time: 1 = marketing + admin only; 2 = + members & Voice; 3 = + report card & election UX.
# Default here is the full platform (Phase 3). For marketing-only deploys, set 1 and omit MEMBER_SESSION_SECRET.
NEXT_PUBLIC_PLATFORM_PHASE=3

# Optional: public phone line (shown in top bar when set; E.164 recommended)
# NEXT_PUBLIC_CONTACT_PHONE=+233XXXXXXXXX
#
# --- Top bar social (optional; icons default to /contact until set) ---
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourpage
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/your-org
# NEXT_PUBLIC_TWITTER_URL=https://x.com/yourhandle

# --- Postgres (Prisma) — required for admin + news from DB ---
# Local Docker Compose: Postgres is published on host port 55432 by default (see docker-compose.yml POSTGRES_HOST_PORT).
DATABASE_URL=postgresql://mbkru:mbkru_dev@localhost:55432/mbkru

# --- Admin (first user; seed creates/updates this account) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
# JWT signing secret for admin session cookie (min 32 characters in production)
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes

# --- Member accounts (Phase 2+; requires NEXT_PUBLIC_PLATFORM_PHASE >= 2 at build time) ---
# REQUIRED at runtime when phase ≥ 2: without it, /login and /api/auth/login return 503.
# Must differ from ADMIN_SESSION_SECRET — min 32 characters in production.
MEMBER_SESSION_SECRET=replace-with-a-different-32-plus-byte-secret-than-admin

# --- Optional: Google Search Console (HTML tag verification) ---
# Paste the content value from Search Console’s “HTML tag” method (not the whole tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: Newsletter → ESP (after LeadCapture upsert on /api/newsletter) ---
# Mailchimp (Marketing API): key includes datacenter suffix (e.g. ...-us19). List = Audience ID.
# MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us19
# MAILCHIMP_LIST_ID=xxxxxxxxxx
# ConvertKit (v3): API secret from account settings + numeric form ID. Ignored if Mailchimp vars are set.
# CONVERTKIT_API_SECRET=xxxxxxxx
# CONVERTKIT_FORM_ID=1234567

# --- Optional: Analytics (public site only; /admin excluded) ---
# GA4: measurement ID from Google Analytics (G-xxxxxxxxxx)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxxxxx
# Plausible: https://plausible.io — set domain as registered in Plausible
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# Self-hosted Plausible script URL (omit to use https://plausible.io/js/script.js)
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.example.com/js/script.js

# --- Optional: Cloudflare Turnstile (public POST forms) ---
# Set both for production. Widget is omitted when site key is unset (local dev).
# https://developers.cloudflare.com/turnstile/
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# --- Optional: MBKRU Voice — anonymous attachment uploads after submit ---
# HMAC secret (≥32 chars). When set, POST /api/reports returns attachmentUploadToken; unsigned-in users can POST files to /api/reports/[id]/attachments within ~1h. Members can upload via session without this.
# REPORT_ATTACHMENT_HMAC_SECRET=replace-with-at-least-32-random-bytes

# --- Optional: SMS when report status changes (Phase 2+) ---
# SMS_PROVIDER=log — print body to server logs (dev). SMS_PROVIDER=twilio — send via Twilio REST (no extra npm deps).
# Omit or empty = no SMS. Numbers must be E.164 (+country…). Anonymous reporters can set phone on the Voice form;
# members use profile `phone` when present.
# SMS_PROVIDER=log
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+15551234567

# --- Optional: Contact form email (Resend) ---
# https://resend.com — verify domain or use onboarding@resend.dev for tests
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_INBOX_EMAIL=you@yourdomain.com
# RESEND_FROM_EMAIL=MBKRU <noreply@yourdomain.com>
# Also used for MBKRU Voice: report status changes and optional team-note / “note visible again” emails to submitters.
#
# Optional: staff ping when someone joins Parliament tracker waitlist or early-access (same Resend key).
# LEADS_STAFF_INBOX_EMAIL=ops@yourdomain.com

# --- Petitions: guest email confirmation (optional) ---
# When set to 1 with RESEND_API_KEY and NEXT_PUBLIC_SITE_URL (https), guests get a 48h link before signatures count.
# Signed-in members are unaffected (instant sign).
# PETITION_VERIFY_GUEST_SIGNATURES=1
#
# Optional: daily cron to delete expired guest pending rows (Bearer or x-cron-secret header)
# POST https://your-domain/api/cron/cleanup-petition-pending
# CRON_SECRET=long-random-string

# --- Optional: Redis (shared rate limits across instances + health probe) ---
# Native Redis on your machine (default port):
REDIS_URL=redis://localhost:6379
# Host-side tools against Docker dev Compose (see docker-compose.dev.yml; default published port 56379):
# REDIS_URL=redis://localhost:56379

# --- Public API rate limits (optional; defaults: 30 requests / 60s per IP per route) ---
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=30

# --- Communities (Phase 2+) ---
# When unset or any value except "false", new posts from ordinary members start as PENDING until an admin publishes.
# COMMUNITY_PREMODERATE_DEFAULT=false

# --- Deploy / Docker entrypoint ---
# Leave SKIP_DB_SEED unset (or empty) so each container start runs migrate deploy + prisma db seed.
# Set to 1 only if you manage seeding manually (idempotent upserts; safe to re-run).
# SKIP_DB_SEED=1

# --- Coolify / VPS (Docker) ---
# Image build: npm run build only (no DB required at build time; Dockerfile uses empty DATABASE_URL).
# On each container start, docker-entrypoint.sh runs prisma migrate deploy then prisma db seed
# when DATABASE_URL is set. Set SKIP_DB_SEED=1 in Coolify env if you seed manually.
# See docker-compose.fullstack.yml for a full compose reference.
#
# Public starter data (promises, report-card pilot, communities list) requires seed flags to stay OFF/unset:
#   Do NOT set SEED_ACCOUNTABILITY_DEMO=0 unless you intentionally want empty /promises and /report-card.
#   Do NOT set SEED_COMMUNITIES_DEMO=0 unless you want empty /communities.
# Ops runbooks sometimes suggest disabling demos in production — for this site, leave defaults so seed hydrates editorial samples.

# --- Bundled roster JSON (prisma db seed) ---
# Constituencies load from prisma/data/constituencies.seed.json unless disabled.
# SEED_CONSTITUENCIES_JSON=0
# Full MP list: bundled prisma/data/parliament-members.seed.json (Wikipedia 2024 list; npm run data:refresh-members-seed-wikipedia).
# SEED_PARLIAMENT_MEMBERS_JSON=0

# --- Public accountability starter (sample MPs + manifesto-linked themes) ---
# Runs on every `prisma db seed` unless you opt out. Upserts overlap slugs with bundled MP JSON if both run.
# SEED_ACCOUNTABILITY_DEMO=0

# --- Town hall / forum programme placeholders (TownHallEvent) — see prisma/data/TOWN_HALL_SEED_SOURCES.txt ---
# SEED_TOWN_HALL_PROGRAMME=0

# --- Traditional-area communities (Phase 4) — prisma/data/communities.seed.json + optional pilot posts ---
# Runs unless SEED_COMMUNITIES_DEMO=0. Pilot posts/memberships require SEED_MEMBER_DEMO=1.
# SEED_COMMUNITIES_DEMO=0

# --- Engagement fixtures (admin/workflow): Voice + attachment, situational & election rows, contact, verification queue ---
# CitizenReport rows use staffNotes for seed provenance; disable in production if you want zero preloaded rows.
# SEED_ENGAGEMENT_DEMOS=1 also seeds 10 demo members (demo.cohort01@mbkru.local …), linked reports, community rows, lead captures.
# Optional password override for that cohort: SEED_DEMO_COHORT_PASSWORD=...
# SEED_ENGAGEMENT_DEMOS=1
# SEED_VOICE_DEMO=1

# --- Optional: seed fictional public Member accounts for /login (Phase 2+ local/staging) ---
# SEED_MEMBER_DEMO=1
# SEED_MEMBER_EMAIL=pilot.member@mbkru.local
# SEED_MEMBER_PASSWORD=PilotMember!change-me-2026
# SEED_MEMBER_2_EMAIL=pilot.two@mbkru.local
# SEED_MEMBER_2_PASSWORD=PilotMember!change-me-2026

# --- Docker Compose (optional overrides) ---
# HOST_PORT=1100
# POSTGRES_USER=mbkru
# POSTGRES_PASSWORD=mbkru_dev
# POSTGRES_DB=mbkru
