# MBKRU website — copy to .env and fill in (never commit .env)

# Public site URL (used for metadata, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:1100

# Platform phase at build time: 1 = marketing + admin only; 2 = + members & Voice; 3 = + report card & election UX.
# Default here is the full platform (Phase 3). For marketing-only deploys, set 1 and omit MEMBER_SESSION_SECRET.
NEXT_PUBLIC_PLATFORM_PHASE=3

# Optional: public phone line (shown in top bar when set; E.164 recommended)
# NEXT_PUBLIC_CONTACT_PHONE=+233XXXXXXXXX

# --- Postgres (Prisma) — required for admin + news from DB ---
# Local Docker Compose: Postgres is published on host port 55432 by default (see docker-compose.yml POSTGRES_HOST_PORT).
DATABASE_URL=postgresql://mbkru:mbkru_dev@localhost:55432/mbkru

# --- Admin (first user; seed creates/updates this account) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
# JWT signing secret for admin session cookie (min 32 characters in production)
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes

# --- Member accounts (Phase 2+; requires NEXT_PUBLIC_PLATFORM_PHASE >= 2 at build time) ---
# REQUIRED at runtime when phase ≥ 2: without it, /login and /api/auth/login return 503.
# Must differ from ADMIN_SESSION_SECRET — min 32 characters in production.
MEMBER_SESSION_SECRET=replace-with-a-different-32-plus-byte-secret-than-admin

# --- Optional: Analytics (public site only; /admin excluded) ---
# GA4: measurement ID from Google Analytics (G-xxxxxxxxxx)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxxxxx
# Plausible: https://plausible.io — set domain as registered in Plausible
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# Self-hosted Plausible script URL (omit to use https://plausible.io/js/script.js)
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.example.com/js/script.js

# --- Optional: Cloudflare Turnstile (public POST forms) ---
# Set both for production. Widget is omitted when site key is unset (local dev).
# https://developers.cloudflare.com/turnstile/
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# --- Optional: MBKRU Voice — anonymous attachment uploads after submit ---
# HMAC secret (≥32 chars). When set, POST /api/reports returns attachmentUploadToken; unsigned-in users can POST files to /api/reports/[id]/attachments within ~1h. Members can upload via session without this.
# REPORT_ATTACHMENT_HMAC_SECRET=replace-with-at-least-32-random-bytes

# --- Optional: SMS when report status changes (Phase 2+) ---
# SMS_PROVIDER=log — print body to server logs (dev). SMS_PROVIDER=twilio — send via Twilio REST (no extra npm deps).
# Omit or empty = no SMS. Numbers must be E.164 (+country…). Anonymous reporters can set phone on the Voice form;
# members use profile `phone` when present.
# SMS_PROVIDER=log
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+15551234567

# --- Optional: Contact form email (Resend) ---
# https://resend.com — verify domain or use onboarding@resend.dev for tests
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_INBOX_EMAIL=you@yourdomain.com
# RESEND_FROM_EMAIL=MBKRU <noreply@yourdomain.com>

# --- Optional: Redis (shared rate limits across instances + health probe) ---
REDIS_URL=redis://localhost:6379

# --- Public API rate limits (optional; defaults: 30 requests / 60s per IP per route) ---
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=30

# --- Communities (Phase 2+) ---
# When unset or any value except "false", new posts from ordinary members start as PENDING until an admin publishes.
# COMMUNITY_PREMODERATE_DEFAULT=false

# --- Deploy / Docker entrypoint ---
# Set to 1 to skip prisma db seed on container start (migrations still run).
# SKIP_DB_SEED=0

# --- Public accountability starter (sample MPs from parliament.gh-style roster + manifesto-linked themes) ---
# Runs on every `prisma db seed` unless you opt out. Full roster: CSV import per docs/DATA_SOURCES.md.
# SEED_ACCOUNTABILITY_DEMO=0

# --- Optional: seed fictional public Member accounts for /login (Phase 2+ local/staging) ---
# SEED_MEMBER_DEMO=1
# SEED_MEMBER_EMAIL=pilot.member@mbkru.local
# SEED_MEMBER_PASSWORD=PilotMember!change-me-2026
# SEED_MEMBER_2_EMAIL=pilot.two@mbkru.local
# SEED_MEMBER_2_PASSWORD=PilotMember!change-me-2026

# --- Docker Compose (optional overrides) ---
# HOST_PORT=1100
# POSTGRES_USER=mbkru
# POSTGRES_PASSWORD=mbkru_dev
# POSTGRES_DB=mbkru
