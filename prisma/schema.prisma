generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single admin account for now (expand to AdminRole / many admins later).
model Admin {
  id                                String                        @id @default(cuid())
  email                             String                        @unique
  password                          String
  createdAt                         DateTime                      @default(now())
  moderatedCommunityPosts           CommunityPost[]               @relation("CommunityPostModerator")
  authoredCitizenReportAdminReplies CitizenReportAdminReply[]     @relation("CitizenReportAdminReplyAuthor")
  editedCitizenReportAdminReplies   CitizenReportAdminReply[]     @relation("CitizenReportAdminReplyEditor")
  citizenReportAdminReplyAuditLogs  CitizenReportAdminReplyAuditLog[]
}

/// Reusable images for posts (and future resources).
model Media {
  id          String      @id @default(cuid())
  filename    String
  storagePath String
  mimeType    String
  alt         String?
  width       Int?
  height      Int?
  createdAt   DateTime    @default(now())
  posts       Post[]
  communityCovers Community[] @relation("CommunityCover")
}

model Post {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?
  body            String    @db.Text
  publishedAt     DateTime?
  featuredMediaId String?
  featuredMedia   Media?    @relation(fields: [featuredMediaId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Public downloads on `/resources` — PDFs and office docs uploaded from admin.
enum ResourceDocumentCategory {
  REPORTS
  POLICY_BRIEFS
  RESEARCH
  OTHER
}

model ResourceDocument {
  id               String                   @id @default(cuid())
  title            String                   @db.VarChar(240)
  slug             String                   @unique @db.VarChar(140)
  summary          String?                  @db.VarChar(600)
  category         ResourceDocumentCategory @default(OTHER)
  /// Path under `public` (e.g. `/uploads/resources/uuid.pdf`)
  filePath         String                   @db.VarChar(500)
  originalFilename String                   @db.VarChar(280)
  mimeType         String                   @db.VarChar(120)
  fileSize         Int?
  publishedAt      DateTime?
  sortOrder        Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([publishedAt, sortOrder])
  @@index([category, sortOrder])
}

/// Marketing / waitlist signups (Phase 1). One row per email per source; upsert is idempotent.
enum LeadCaptureSource {
  NEWSLETTER
  EARLY_ACCESS
  PARLIAMENT_TRACKER
}

model LeadCapture {
  id        String             @id @default(cuid())
  email     String
  source    LeadCaptureSource
  createdAt DateTime           @default(now())

  @@unique([email, source])
  @@index([source, createdAt])
}

model ContactSubmission {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String
  email       String
  subject     String
  message     String   @db.Text
  enquiryType String?

  @@index([createdAt])
  @@index([email])
}

/// Diaspora visit experience & feedback — public form; staff review in admin CMS.
enum DiasporaFeedbackOverallRating {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum DiasporaFeedbackReturnIntent {
  YES
  NO
  MAYBE
}

model DiasporaFeedbackSubmission {
  id                     String                         @id @default(cuid())
  createdAt              DateTime                       @default(now())
  fullName               String                         @db.VarChar(200)
  email                  String                         @db.VarChar(320)
  dateOfVisit            DateTime                       @db.Date
  durationOfStay         String                         @db.VarChar(240)
  eventsAttended         String                         @db.Text
  overallRating          DiasporaFeedbackOverallRating
  meaningfulAspects      String                         @db.Text
  suggestionsImprovement String                         @db.Text
  returnOrInvest         DiasporaFeedbackReturnIntent
  signature              String                         @db.VarChar(200)
  formSignedDate         DateTime                       @db.Date

  @@index([createdAt])
  @@index([email])
}

// --- Phase 2 & 3 — see docs/PHASES_2_3_IMPLEMENTATION.md ---

enum CitizenReportKind {
  VOICE
  SITUATIONAL_ALERT
  ELECTION_OBSERVATION
}

enum CitizenReportStatus {
  RECEIVED
  UNDER_REVIEW
  ESCALATED
  CLOSED
  ARCHIVED
}

enum PromiseStatus {
  TRACKING
  IN_PROGRESS
  FULFILLED
  BROKEN
  DEFERRED
}

enum PetitionStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum PublicCauseCommentStatus {
  VISIBLE
  HIDDEN
}

/// Ghana 16 regions — seeded in prisma/seed.mjs
model Region {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  sortOrder      Int             @default(0)
  members        Member[]
  reports        CitizenReport[]
  constituencies Constituency[]
  communities    Community[]
  townHallEvents TownHallEvent[]
  petitions      Petition[]
}

/// Physical programme rows (town halls / forums / constituency debates). Seeded from roadmap + regional plan; operators replace with confirmed dates.
enum TownHallEventStatus {
  TBC
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ProgrammeEventKind {
  TOWN_HALL
  REGIONAL_FORUM
  CONSTITUENCY_DEBATE
}

model TownHallEvent {
  id               String               @id @default(cuid())
  slug             String               @unique
  title            String
  summary          String?              @db.Text
  kind             ProgrammeEventKind   @default(TOWN_HALL)
  regionId         String?
  region           Region?              @relation(fields: [regionId], references: [id], onDelete: SetNull)
  constituencyId   String?
  constituency     Constituency?        @relation(fields: [constituencyId], references: [id], onDelete: SetNull)
  programmeQuarter String?
  startsAt         DateTime?
  endsAt           DateTime?
  venueLine        String?
  status           TownHallEventStatus  @default(TBC)
  infoUrl          String?              @db.Text
  sourceCitation   String?              @db.Text
  sortOrder        Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([regionId])
  @@index([constituencyId])
  @@index([kind])
  @@index([status, sortOrder])
}

model Constituency {
  id       String   @id @default(cuid())
  name     String
  slug     String   @unique
  code     String?  @unique
  regionId String
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)

  members        ParliamentMember[]
  reports        CitizenReport[]
  townHallEvents TownHallEvent[]

  @@index([regionId])
}

/// Staff-reviewed civic identity (not Ghana Card upload in MVP — status + notes only).
enum MemberIdentityVerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

/// Public registered user (MBKRU Voice) — separate from Admin
model Member {
  id                             String                           @id @default(cuid())
  email                          String                           @unique
  password                       String
  displayName                    String?
  phone                          String?
  regionId                       String?
  region                         Region?                          @relation(fields: [regionId], references: [id], onDelete: SetNull)
  identityVerificationStatus     MemberIdentityVerificationStatus @default(UNVERIFIED)
  identityVerificationNote       String?                          @db.Text
  identityVerifiedAt             DateTime?
  identityReviewRequestedAt      DateTime?
  identityReviewRequestMessage   String?                          @db.VarChar(2000)
  createdAt                      DateTime                         @default(now())
  updatedAt                      DateTime                         @updatedAt
  reports                        CitizenReport[]

  communityMemberships   CommunityMembership[]
  communityPosts         CommunityPost[]
  communityPostReports   CommunityPostReport[]
  verificationRequests   CommunityVerificationRequest[]
  memberNotifications    MemberNotification[]
  petitionsAuthored      Petition[]                 @relation("PetitionAuthor")
  petitionSignatures     PetitionSignature[]
  publicCauseComments    CitizenReportPublicComment[]
  publicCauseSupports    CitizenReportSupport[]

  @@index([regionId])
  @@index([identityVerificationStatus])
}

model CitizenReport {
  id                    String                  @id @default(cuid())
  trackingCode          String                  @unique
  kind                  CitizenReportKind
  memberId              String?
  member                Member?                 @relation(fields: [memberId], references: [id], onDelete: SetNull)
  submitterEmail        String?
  submitterPhone        String?
  title                 String
  body                  String                  @db.Text
  category              String?
  latitude              Float?
  longitude             Float?
  regionId              String?
  region                Region?                 @relation(fields: [regionId], references: [id], onDelete: SetNull)
  constituencyId        String?
  constituency          Constituency?           @relation(fields: [constituencyId], references: [id], onDelete: SetNull)
  status                CitizenReportStatus     @default(RECEIVED)
  slaDueAt              DateTime?
  operationsPlaybookKey String?
  staffNotes            String?                 @db.Text
  /// Staff-approved public thread: sanitized title/summary only (original body stays private).
  publicCauseSlug       String?                 @unique @db.VarChar(120)
  publicCauseTitle      String?                 @db.VarChar(240)
  publicCauseSummary    String?                 @db.Text
  publicCauseOpenedAt   DateTime?
  publicCauseClosed     Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  attachments           CitizenReportAttachment[]
  publicCauseComments   CitizenReportPublicComment[]
  publicCauseSupports   CitizenReportSupport[]
  adminReplies               CitizenReportAdminReply[]
  adminReplyAuditLogs        CitizenReportAdminReplyAuditLog[]

  @@index([kind, status])
  @@index([memberId])
  @@index([slaDueAt])
  @@index([publicCauseOpenedAt])
}

/// Staff message visible to the submitter (signed-in member page + optional email + public track-by-code).
model CitizenReportAdminReply {
  id                   String        @id @default(cuid())
  reportId             String
  report               CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  adminId              String?
  admin                Admin?        @relation("CitizenReportAdminReplyAuthor", fields: [adminId], references: [id], onDelete: SetNull)
  /// Set when an admin saves an edit to `body` (original author remains `adminId`).
  editedByAdminId      String?
  editedBy             Admin?        @relation("CitizenReportAdminReplyEditor", fields: [editedByAdminId], references: [id], onDelete: SetNull)
  body                 String        @db.Text
  /// When false, hidden from My reports and Track a report (admin still sees full history).
  visibleToSubmitter   Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([reportId, createdAt])
  @@index([editedByAdminId])
  auditLogs CitizenReportAdminReplyAuditLog[]
}

/// Append-only admin actions on submitter-visible notes (post, edit, visibility).
model CitizenReportAdminReplyAuditLog {
  id        String                  @id @default(cuid())
  replyId   String
  reply     CitizenReportAdminReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reportId  String
  report    CitizenReport           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  adminId   String?
  admin     Admin?                  @relation(fields: [adminId], references: [id], onDelete: SetNull)
  /// REPLY_POSTED | REPLY_EDITED | REPLY_VISIBILITY
  action    String                  @db.VarChar(32)
  details   Json?
  createdAt DateTime                @default(now())

  @@index([reportId, createdAt])
  @@index([replyId, createdAt])
}

model CitizenReportPublicComment {
  id        String                   @id @default(cuid())
  reportId  String
  report    CitizenReport            @relation(fields: [reportId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  body      String                   @db.VarChar(2000)
  status    PublicCauseCommentStatus @default(VISIBLE)
  createdAt DateTime                 @default(now())

  @@index([reportId, createdAt])
  @@index([memberId])
}

model CitizenReportSupport {
  reportId  String
  report    CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@id([reportId, memberId])
  @@index([reportId])
}

model Petition {
  id               String         @id @default(cuid())
  slug             String         @unique @db.VarChar(140)
  title            String         @db.VarChar(280)
  summary          String?        @db.VarChar(500)
  body             String         @db.Text
  targetSignatures Int?
  regionId         String?
  region           Region?        @relation(fields: [regionId], references: [id], onDelete: SetNull)
  authorMemberId   String
  author           Member         @relation("PetitionAuthor", fields: [authorMemberId], references: [id], onDelete: Restrict)
  status           PetitionStatus @default(OPEN)
  signatures       PetitionSignature[]
  pendingSignatures PetitionSignaturePending[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([authorMemberId])
}

/// Guest signature not counted until email confirmation (see PETITION_VERIFY_GUEST_SIGNATURES).
model PetitionSignaturePending {
  id              String   @id @default(cuid())
  petitionId      String
  petition        Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  signerEmail     String   @db.VarChar(254)
  signerName      String?  @db.VarChar(120)
  consentShowName Boolean  @default(false)
  consentUpdates  Boolean  @default(false)
  /// SHA-256 hex of the secret token sent by email (raw token is never stored).
  tokenHash       String   @unique @db.VarChar(64)
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@unique([petitionId, signerEmail])
  @@index([petitionId])
  @@index([expiresAt])
}

model PetitionSignature {
  id              String   @id @default(cuid())
  petitionId      String
  petition        Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  memberId        String?
  member          Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  signerEmail     String   @db.VarChar(254)
  signerName      String?  @db.VarChar(120)
  consentShowName Boolean  @default(false)
  consentUpdates  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([petitionId, signerEmail])
  @@index([petitionId])
  @@index([memberId])
}

model CitizenReportAttachment {
  id        String        @id @default(cuid())
  reportId  String
  report    CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  path      String
  mimeType  String
  createdAt DateTime      @default(now())

  @@index([reportId])
}

model ParliamentMember {
  id                 String        @id @default(cuid())
  name               String
  slug               String        @unique
  role               String
  party              String?
  constituencyId     String?
  constituency       Constituency? @relation(fields: [constituencyId], references: [id], onDelete: SetNull)
  portraitPath       String?
  active             Boolean       @default(true)
  lastVerifiedAt     DateTime?
  externalSourceKey  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  promises           CampaignPromise[]
  scoreEntries       ScorecardEntry[]

  @@index([constituencyId])
}

/// Party manifesto metadata (full PDF not stored; cite in CampaignPromise).
model ManifestoDocument {
  id            String            @id @default(cuid())
  title         String
  partySlug     String
  electionCycle String
  sourceUrl     String            @db.Text
  sha256        String?
  publishedAt   DateTime?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  promises      CampaignPromise[]

  @@index([partySlug, electionCycle])
}

model CampaignPromise {
  id                    String             @id @default(cuid())
  memberId              String?
  member                ParliamentMember?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  title                 String
  description           String?            @db.Text
  sourceLabel           String
  /// Canonical URL for the cited source (speech, Hansard, party PDF, etc.). Falls back to manifesto document URL in UI when unset.
  sourceUrl             String?            @db.Text
  sourceDate            DateTime?
  /// Editorial verification / impact notes shown on public commitment cards.
  verificationNotes     String?            @db.Text
  status                PromiseStatus      @default(TRACKING)
  electionCycle         String?
  partySlug             String?
  manifestoDocumentId   String?
  manifestoDocument     ManifestoDocument? @relation(fields: [manifestoDocumentId], references: [id], onDelete: SetNull)
  manifestoPageRef      String?
  isGovernmentProgramme Boolean            @default(false)
  /// Optional theme for filters (e.g. FISCAL, EDUCATION). See `POLICY_SECTORS` in app code.
  policySector          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([memberId])
  @@index([partySlug, electionCycle])
  @@index([isGovernmentProgramme])
  @@index([policySector])
}

model ReportCardCycle {
  id          String           @id @default(cuid())
  year        Int              @unique
  label       String
  publishedAt DateTime?
  methodology String?          @db.Text
  entries     ScorecardEntry[]
}

model ScorecardEntry {
  id           String             @id @default(cuid())
  cycleId      String
  cycle        ReportCardCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  memberId     String
  member       ParliamentMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  narrative    String?            @db.Text
  overallScore Float?
  metrics      Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([cycleId, memberId])
}

// --- Phase 4 — Communities (Queen Mothers & traditional areas) ---

enum CommunityVisibility {
  PUBLIC
  MEMBERS_ONLY
}

enum CommunityJoinPolicy {
  OPEN
  APPROVAL_REQUIRED
}

enum CommunityStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CommunityMembershipRole {
  MEMBER
  MODERATOR
  QUEEN_MOTHER_VERIFIED
}

enum CommunityMembershipState {
  ACTIVE
  PENDING_JOIN
  SUSPENDED
  BANNED
}

enum CommunityPostKind {
  GENERAL
  CONCERN
  ANNOUNCEMENT
}

enum CommunityPostModerationStatus {
  PENDING
  PUBLISHED
  REJECTED
  HIDDEN
}

enum CommunityVerificationStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum CommunityPostReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model Community {
  id                  String              @id @default(cuid())
  slug                String              @unique
  name                String
  description         String              @db.Text
  regionId            String?
  region              Region?             @relation(fields: [regionId], references: [id], onDelete: SetNull)
  traditionalAreaName String?
  visibility          CommunityVisibility @default(PUBLIC)
  joinPolicy          CommunityJoinPolicy @default(OPEN)
  status              CommunityStatus     @default(DRAFT)
  coverMediaId        String?
  coverMedia          Media?              @relation("CommunityCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  memberships    CommunityMembership[]
  forums         CommunityForum[]
  posts          CommunityPost[]
  verifications  CommunityVerificationRequest[]

  @@index([regionId])
  @@index([status])
}

/// Discussion area inside a community (e.g. General, Projects). Threads are root-level posts with optional title.
model CommunityForum {
  id          String   @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  slug        String
  name        String
  description String?  @db.Text
  locked      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       CommunityPost[]

  @@unique([communityId, slug])
  @@index([communityId])
}

model CommunityMembership {
  id          String                   @id @default(cuid())
  communityId String
  community   Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  memberId    String
  member      Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role        CommunityMembershipRole  @default(MEMBER)
  state       CommunityMembershipState @default(ACTIVE)
  banReason   String?                  @db.Text
  bannedAt    DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([communityId, memberId])
  @@index([communityId])
  @@index([memberId])
}

model CommunityPost {
  id                   String                        @id @default(cuid())
  communityId          String
  community            Community                     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  communityForumId     String?
  communityForum       CommunityForum?               @relation(fields: [communityForumId], references: [id], onDelete: SetNull)
  parentPostId         String?
  parentPost           CommunityPost?                @relation("CommunityPostReplies", fields: [parentPostId], references: [id], onDelete: Cascade)
  replies              CommunityPost[]               @relation("CommunityPostReplies")
  authorMemberId       String
  author               Member                        @relation(fields: [authorMemberId], references: [id], onDelete: Cascade)
  kind                 CommunityPostKind
  title                String?                       @db.VarChar(200)
  body                 String                        @db.Text
  moderationStatus     CommunityPostModerationStatus @default(PENDING)
  pinned               Boolean                       @default(false)
  moderatedAt          DateTime?
  moderatedByAdminId   String?
  moderatedBy          Admin?                        @relation("CommunityPostModerator", fields: [moderatedByAdminId], references: [id], onDelete: SetNull)
  rejectionReason      String?                       @db.Text
  createdAt            DateTime                      @default(now())
  /** For root posts (`parentPostId` null): bumped when a published reply lands — forum sort uses this. */
  lastActivityAt       DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  reports CommunityPostReport[]

  @@index([communityId, createdAt])
  @@index([communityId, moderationStatus])
  @@index([authorMemberId])
  @@index([communityForumId, createdAt])
  @@index([communityForumId, lastActivityAt])
  @@index([parentPostId, createdAt])
}

model CommunityPostReport {
  id               String                    @id @default(cuid())
  postId           String
  post             CommunityPost             @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporterMemberId String
  reporter         Member                    @relation(fields: [reporterMemberId], references: [id], onDelete: Cascade)
  reason           String                    @db.VarChar(120)
  details          String?                   @db.Text
  status           CommunityPostReportStatus @default(OPEN)
  reviewedAt       DateTime?
  createdAt        DateTime                  @default(now())

  @@index([postId])
  @@index([status])
}

model CommunityVerificationRequest {
  id               String                    @id @default(cuid())
  communityId      String
  community        Community                 @relation(fields: [communityId], references: [id], onDelete: Cascade)
  memberId         String
  member           Member                    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status           CommunityVerificationStatus @default(SUBMITTED)
  documentMediaIds Json
  reviewNotes      String?                   @db.Text
  reviewedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([communityId, status])
  @@index([memberId])
}

model MemberNotification {
  id        String    @id @default(cuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([memberId, readAt])
}

/// Aggregated UI telemetry for MBKRU Voice and accessibility tools (`POST /api/analytics/mbkru-voice-event`).
/// `src/lib/server/mbkru-voice-analytics.ts` still calls `ensureAnalyticsTable()` so older deployments
/// without this migration get the DDL on first write; new installs should rely on `prisma migrate deploy`.
model MbkruVoiceAnalyticsEvent {
  id        BigInt   @id @default(autoincrement())
  eventName String   @map("event_name") @db.VarChar(120)
  source    String   @default("client") @db.VarChar(32)
  language  String?  @db.VarChar(16)
  payload   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([eventName])
  @@map("mbkru_voice_analytics_events")
}
